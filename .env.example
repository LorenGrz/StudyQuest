# =============================================
# StudyQuest – Variables de entorno (raíz)
# Copia este archivo como .env y completá los valores
# =============================================

# --- Base de datos (PostgreSQL) ---
POSTGRES_USER=studyquest
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURA
POSTGRES_DB=studyquest

# --- Redis ---
REDIS_PASSWORD=CAMBIAR_REDIS_PASSWORD

# --- Autenticación ---
JWT_SECRET=CAMBIAR_SECRET_MUY_LARGA_Y_ALEATORIA

# --- Google Gemini AI ---
GEMINI_API_KEY=TU_API_KEY_DE_GOOGLE_GEMINI
GEMINI_MODEL=gemini-1.5-flash
